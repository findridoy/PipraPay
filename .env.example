# PipraPay Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# MySQL Database Configuration (External)
# =============================================================================
# These variables are used to connect to your external MySQL database
DB_HOST=your-mysql-host.example.com
DB_PORT=3306
DB_NAME=piprapay
DB_USER=piprapay
DB_PASS=your-secure-password-here
DB_PREFIX=pp_

# =============================================================================
# Admin Account Configuration
# =============================================================================
# These settings are used to create the initial administrator account
# If ADMIN_PASSWORD is empty, a secure password will be auto-generated and
# displayed in the container logs. Save it immediately!

ADMIN_NAME=Administrator
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# =============================================================================
# Setup Options
# =============================================================================
# Set to "true" to skip auto-setup and use the web installer at /install
SKIP_AUTO_SETUP=false

# Set to "true" to force re-run setup even if already completed (DANGEROUS!)
# This will NOT overwrite existing data, but may cause issues
FORCE_SETUP=false

# =============================================================================
# PHP Configuration (Optional)
# =============================================================================
PHP_MEMORY_LIMIT=256M
PHP_UPLOAD_MAX_FILESIZE=64M
PHP_POST_MAX_SIZE=64M
PHP_MAX_EXECUTION_TIME=300
